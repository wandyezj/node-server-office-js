{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Watch Compile",
            "command": "npm",
            "args": ["run", "watch-compile"],
            "options": {
                "cwd": "${workspaceFolder}/src"
            }
        },
        {
            "label": "Watch Server",
            "command": "npm",
            "args": ["run", "watch-server"],
            "options": {
                "cwd": "${workspaceFolder}/src"
            }
        },
        {
            "label": "Start",
            "dependsOn": ["Watch Compile", "Watch Server"],
            "group": {
                "kind": "build",
                "isDefault": true // Makes this the default build task
            }
        }
    ]
}
