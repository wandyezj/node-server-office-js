{
    "name": "node-server-office-js",
    "version": "0.0.0",
    "description": "Node server to execute office.js on an Office Document.",
    "main": "index.js",
    "private": true,
    "scripts": {
        "style": "prettier --config ./config/prettier.json --write \"@(src|test)/**/*.@(ts|tsx|js|md|html|css|json)\"",
        "style-check": "prettier --config ./config/prettier.json --check \"@(src|test)/**/*.@(ts|tsx|js|md|html|css|json)\"",
        "ping": "ts-node ./scripts/ping.ts",
        "test": "playwright test --config ./config/playwright.config.ts",
        "test:ui": "playwright test --config ./config/playwright.config.ts --ui",
        "clean": "node ./scripts/clean.js dist",
        "compile": "webpack --config ./config/webpack.config.js --mode production",
        "watch-compile": "webpack --config ./config/webpack.config.js --mode development --watch",
        "watch-server": "node --watch ./dist/index.bundle.js",
        "start": "npm run watch-compile & npm run watch-server",
        "read-manifest-registry": "ts-node ./scripts/read-manifest-registry.ts",
        "excel-open": "npm run ping -- --open-excel",
        "excel-ping": "npm run ping -- --addin-ping",
        "excel-eval": "npm run ping -- --addin-eval",
        "cert-install": "npx office-addin-dev-certs install",
        "cert-verify": "npx office-addin-dev-certs verify",
        "format-ooxml": "node ./scripts/crack-and-format-ooxml.js --output-directory ./test-results/ooxml --input-file-path",
        "format-test": "npm run format-ooxml -- ./test/test.xlsx && npm run format-ooxml -- ./test/test-temp.xlsx && npm run format-ooxml -- ./test/test-out.xlsx"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/wandyezj/node-server-office-js.git"
    },
    "author": "wandyezj",
    "license": "Unlicensed",
    "bugs": {
        "url": "https://github.com/wandyezj/node-server-office-js/issues"
    },
    "homepage": "https://github.com/wandyezj/node-server-office-js#readme",
    "devDependencies": {
        "@playwright/test": "^1.59.1",
        "@types/adm-zip": "^0.5.8",
        "@types/html-webpack-plugin": "^3.2.9",
        "@types/node": "^22.15.2",
        "@types/office-js": "^1.0.587",
        "@types/ws": "^8.18.1",
        "clean-webpack-plugin": "^4.0.0",
        "copy-webpack-plugin": "^14.0.0",
        "html-webpack-plugin": "^5.6.6",
        "office-addin-dev-certs": "^1.9.1",
        "prettier": "3.8.3",
        "ts-loader": "^9.5.4",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.2",
        "webpack": "^5.104.1",
        "webpack-cli": "^6.0.1"
    },
    "dependencies": {
        "@prettier/plugin-xml": "^3.4.2",
        "@xmldom/xmldom": "^0.9.9",
        "adm-zip": "^0.5.17",
        "ws": "^8.20.0"
    }
}
