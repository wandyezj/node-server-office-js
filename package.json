{
  "name": "node-server-office-js",
  "version": "0.0.0",
  "description": "Node server to execute office.js on an Office Document.",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "node ./dist/index.js",
    "dev": "npm run build && npm start",
    "test": "playwright test --config ./configs/playwright.config.ts",
    "test:ui": "playwright test --config ./configs/playwright.config.ts --ui"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wandyezj/node-server-office-js.git"
  },
